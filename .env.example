# Database (Supabase pooler recommended)
DATABASE_URL=postgresql://user:pass@host:6543/postgres

# Auth
JWT_SECRET=your-secret-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
EXCHANGE_RATE=74.5

# App URL (password reset links)
NEXT_PUBLIC_APP_URL=https://umrahcal.skyshiptravels.com

# Email (Resend — optional; logs to console if unset)
RESEND_API_KEY=
EMAIL_FROM=noreply@skyshiptravels.com

# Sentry (optional — skip if unset)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
